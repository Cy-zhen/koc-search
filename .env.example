# YouTube Data API v3 Key
# 在 https://console.cloud.google.com/ 创建
YOUTUBE_API_KEY=your_youtube_api_key_here

# 服务端口
PORT=3000

# Playwright 浏览器配置
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=100

# 任务管理
# 任务记录保留时长（毫秒），默认 6 小时
TASK_TTL_MS=21600000
# 最大任务缓存数，超过后会清理最旧任务
MAX_TASKS=200

# 可选：MCP 抓取网关（配置后，小红书/抖音/TikTok 走远端执行）
# 示例: https://your-mcp-gateway.example.com
MCP_GATEWAY_URL=
# 可选：网关鉴权 Token
MCP_GATEWAY_TOKEN=
